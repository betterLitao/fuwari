[Unit]
Description=Fuwari Blog Publish Worker
After=network.target

[Service]
Type=oneshot
WorkingDirectory=/www/wwwroot/fuwari-blog
EnvironmentFile=/www/wwwroot/fuwari-blog/.env.production
Environment=NODE_ENV=production
ExecStart=/usr/bin/corepack pnpm build
ExecStartPost=/usr/bin/systemctl restart fuwari-blog.service

[Install]
WantedBy=multi-user.target
