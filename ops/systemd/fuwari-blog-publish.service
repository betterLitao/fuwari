[Unit]
Description=Fuwari Blog Publish Worker
After=network.target

[Service]
Type=oneshot
WorkingDirectory=/www/wwwroot/fuwari-blog/current
EnvironmentFile=/www/wwwroot/fuwari-blog/shared/.env.production
Environment=NODE_ENV=production
Environment=HOME=/root
Environment=PATH=/usr/local/bin:/usr/bin:/bin
ExecStart=/bin/bash /www/wwwroot/fuwari-blog/current/ops/publish-site.sh

[Install]
WantedBy=multi-user.target
